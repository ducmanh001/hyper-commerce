{
  "description": "HyperCommerce Infrastructure — CPU, Memory, Redis, Kafka, PostgreSQL, Elasticsearch",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "row",
      "title": "🖥️ Service Resource Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },

    {
      "type": "timeseries",
      "title": "CPU Usage by Service (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 5 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service) (rate(process_cpu_seconds_total[2m])) * 100",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Memory Usage by Service (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 5 }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "🔴 Redis Cluster",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "collapsed": false
    },

    {
      "type": "stat",
      "title": "Redis Memory Usage",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "id": 20,
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Redis Hit Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "id": 21,
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Redis OPS/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 22,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Commands/sec",
          "refId": "A"
        },
        {
          "expr": "rate(redis_connections_received_total[1m])",
          "legendFormat": "New Connections/sec",
          "refId": "B"
        }
      ]
    },

    {
      "type": "row",
      "title": "📨 Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "collapsed": false
    },

    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag by Group",
      "description": "Alert fires at 10K lag",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "id": 30,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_consumer_group_lag",
          "legendFormat": "{{group}} / {{topic}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Kafka Publish Errors (1h)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 19 },
      "id": 31,
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(hc_kafka_publish_errors_total[1h]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "🐘 PostgreSQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 400,
      "collapsed": false
    },

    {
      "type": "timeseries",
      "title": "PostgreSQL Connections",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 40,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineInterpolation": "smooth" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max Connections" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname='hypercommerce'}",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max Connections", "refId": "B" }
      ]
    },

    {
      "type": "timeseries",
      "title": "PostgreSQL QPS (queries/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 41,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname='hypercommerce'}[1m])",
          "legendFormat": "Commits/sec",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname='hypercommerce'}[1m])",
          "legendFormat": "Rollbacks/sec",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["infrastructure", "hypercommerce"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "01 — Infrastructure",
  "uid": "hc-infrastructure",
  "version": 1
}
