NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=hypercommerce
DB_PASSWORD=hypercommerce_secret
DB_NAME=hypercommerce
DB_POOL_MAX=10
DB_POOL_MIN=2

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=localhost:29092

# JWT
JWT_SECRET=hypercommerce_dev_jwt_secret_change_in_prod
JWT_EXPIRES_IN=86400

# Service ports
PORT=3005
INVENTORY_PORT=3002
ORDER_PORT=3003
LIVE_PORT=3007
PAYMENT_PORT=3004
NOTIFICATION_PORT=3008
ANALYTICS_PORT=3009
SEARCH_PORT=3010

# CORS
CORS_ORIGINS=http://localhost:3000

# Internal
INTERNAL_SERVICE_TOKEN=internal_dev_token_change_in_prod

# Logging
LOG_LEVEL=debug
