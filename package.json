{
  "name": "hypercommerce",
  "version": "1.0.0",
  "description": "Real-time Social Commerce Platform — 50M DAU, 500K orders/day, 100K concurrent livestreams",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build:user": "nest build user-service",
    "build:feed": "nest build feed-service",
    "build:order": "nest build order-service",
    "build:inventory": "nest build inventory-service",
    "build:search": "nest build search-service",
    "build:live": "nest build live-service",
    "build:payment": "nest build payment-service",
    "build:notification": "nest build notification-service",
    "build:analytics": "nest build analytics-service",
    "build:ai": "nest build ai-service",
    "build:all": "npm run build:user && npm run build:feed && npm run build:order && npm run build:inventory && npm run build:search && npm run build:live && npm run build:payment && npm run build:notification && npm run build:analytics && npm run build:ai",
    "start:dev:user": "nest start user-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:feed": "nest start feed-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:order": "nest start order-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:inventory": "nest start inventory-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:search": "nest start search-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:live": "nest start live-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:payment": "nest start payment-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:notification": "nest start notification-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:analytics": "nest start analytics-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "start:dev:ai": "nest start ai-service --watch -e 'node_modules/.bin/ts-node -r tsconfig-paths/register --project tsconfig.json'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --forceExit --detectOpenHandles --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit --incremental false",
    "prepare": "husky",
    "ci:local": "npm run lint:check && npm run type-check && npm run format:check && npm audit --audit-level=critical --omit=dev && echo '✅ All CI checks passed locally'",
    "start:gateway": "KAFKAJS_NO_PARTITIONER_WARNING=1 node apps/api-gateway/server.js"
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@clickhouse/client": "^1.19.0",
    "@elastic/elasticsearch": "^8.15.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/elasticsearch": "^11.1.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-jaeger": "^1.26.0",
    "@opentelemetry/exporter-prometheus": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "cassandra-driver": "^4.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "elasticsearch": "^16.7.3",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "nestjs-pino": "^4.1.0",
    "openai": "^4.63.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "stripe": "^16.12.0",
    "twilio": "^6.0.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@hypercommerce/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@hypercommerce/kafka(|/.*)$": "<rootDir>/libs/kafka/src/$1",
      "^@hypercommerce/redis(|/.*)$": "<rootDir>/libs/redis/src/$1",
      "^@hypercommerce/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@hypercommerce/tracing(|/.*)$": "<rootDir>/libs/tracing/src/$1",
      "^@hypercommerce/events(|/.*)$": "<rootDir>/libs/events/src/$1"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
