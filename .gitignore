# ====================================================================
# 1. LOẠI BỎ THƯ MỤC BUILD / OUTPUT (Ở GỐC VÀ TẤT CẢ CÁC THƯ MỤC CON)
# ====================================================================
# Thêm / ở cuối để Git hiểu đây là thư mục.
# Không thêm / ở đầu để nó tự động áp dụng từ root cho đến các thư mục con sâu nhất (children).
build/
dist/
out/
.next/
.nuxt/
bin/
obj/

# ====================================================================
# 2. LOẠI BỎ DEPENDENCIES (NODE_MODULES VÀ CÁC THƯ VIỆN KHÁC)
# ====================================================================
node_modules/
jspm_packages/
web_modules/

# Lock files — KHÔNG gitignore package-lock.json!
# package-lock.json PHẢI được commit để CI (npm ci) hoạt động đúng.
# Gitignore yarn/pnpm lock nếu dự án dùng npm.
yarn.lock
pnpm-lock.yaml

# ====================================================================
# 2b. BUILD CACHE & GENERATED FILES
# ====================================================================
# TypeScript incremental build info (tsc --incremental tạo ra)
*.tsbuildinfo

# Jest coverage reports
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# # ====================================================================
# # 2c. ENVIRONMENT FILES (nhạy cảm — không bao giờ commit)
# # ====================================================================
# .env
# .env.local
# .env.*.local
# .env.test.local
# .env.production.local
# # Cho phép commit .env.example (template không chứa secrets)
# !.env.example

# ====================================================================
# 3. BẢO MẬT: LOẠI BỎ CÁC FILE CẤU HÌNH MÔI TRƯỜNG (ENV, TOKEN, KEY)
# ====================================================================
# CRITICAL: Không bao giờ được push các file này lên GitHub
*.pem
*.key
id_rsa
id_edd25519

# ====================================================================
# 4. CẤU HÌNH HỆ ĐIỀU HÀNH & TRÌNH SOẠN THẢO (OS & IDEs)
# ====================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code (Giữ lại cấu hình chung, loại bỏ dữ liệu tạm của các extension)
.vscode/*
