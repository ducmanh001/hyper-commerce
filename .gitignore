# ====================================================================
# 1. LOẠI BỎ THƯ MỤC BUILD / OUTPUT (Ở GỐC VÀ TẤT CẢ CÁC THƯ MỤC CON)
# ====================================================================
# Thêm / ở cuối để Git hiểu đây là thư mục.
# Không thêm / ở đầu để nó tự động áp dụng từ root cho đến các thư mục con sâu nhất (children).
build/
dist/
out/
.next/
.nuxt/
bin/
obj/

# ====================================================================
# 2. LOẠI BỎ DEPENDENCIES (NODE_MODULES VÀ CÁC THƯ VIỆN KHÁC)
# ====================================================================
node_modules/
jspm_packages/
web_modules/

# Loại bỏ các file log lỗi sinh ra trong quá trình chạy node
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ====================================================================
# 3. BẢO MẬT: LOẠI BỎ CÁC FILE CẤU HÌNH MÔI TRƯỜNG (ENV, TOKEN, KEY)
# ====================================================================
# CRITICAL: Không bao giờ được push các file này lên GitHub
*.pem
*.key
id_rsa
id_edd25519

# ====================================================================
# 4. CẤU HÌNH HỆ ĐIỀU HÀNH & TRÌNH SOẠN THẢO (OS & IDEs)
# ====================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code (Giữ lại cấu hình chung, loại bỏ dữ liệu tạm của các extension)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.history/
.ionide/
