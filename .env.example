# =============================================================================
# HYPERCOMMERCE — Environment Variables
# Copy to .env and fill in real values
# =============================================================================

# App
NODE_ENV=development
APP_PORT=3000
APP_NAME=hypercommerce

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# PostgreSQL (Citus Sharded)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hypercommerce
DB_PASSWORD=secret
DB_DATABASE=hypercommerce
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_SSL=false
# Citus coordinator
CITUS_HOST=localhost
CITUS_PORT=5432

# Cassandra (feed, events)
CASSANDRA_CONTACT_POINTS=localhost:9042
CASSANDRA_LOCAL_DATA_CENTER=datacenter1
CASSANDRA_KEYSPACE=hypercommerce_feed
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra
CASSANDRA_POOL_SIZE=4

# Redis Cluster (16384 slots, 6 nodes)
REDIS_CLUSTER_NODES=localhost:7001,localhost:7002,localhost:7003,localhost:7004,localhost:7005,localhost:7006
REDIS_PASSWORD=
REDIS_TLS=false
# Standalone (dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Kafka (3 brokers, RF=3, min.insync=2)
KAFKA_BROKERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_CLIENT_ID=hypercommerce
KAFKA_GROUP_ID=hypercommerce-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_RETENTION_MS=604800000  # 7 days

# Elasticsearch
ES_NODE=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=elastic
ES_INDEX_PRODUCTS=products
ES_INDEX_USERS=users
ES_VECTOR_DIMS=768

# OpenAI (embeddings + AI features)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o

# Stripe (payment)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_API_VERSION=2024-06-20

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# SendGrid (email)
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_FROM_EMAIL=noreply@hypercommerce.io
SENDGRID_FROM_NAME=HyperCommerce

# AWS S3 (media storage)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxx
AWS_S3_BUCKET=hypercommerce-media
AWS_CLOUDFRONT_DOMAIN=cdn.hypercommerce.io

# Cloudflare
CF_ZONE_ID=xxxxxxxx
CF_API_TOKEN=xxxxxxxx

# ClickHouse (analytics OLAP)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=hypercommerce_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# Observability
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9090
OTEL_SERVICE_NAME=hypercommerce
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Feature Flags
FEATURE_FLAG_FLASH_SALE_V2=true
FEATURE_FLAG_AI_RANKING=true
FEATURE_FLAG_AR_PREVIEW=false
FEATURE_FLAG_WEB3=false

# Rate Limiting
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_FREE_RPM=60
RATE_LIMIT_SELLER_RPM=300
RATE_LIMIT_PREMIUM_RPM=1000

# Inventory
CELEBRITY_FOLLOWER_THRESHOLD=10000
STOCK_RESERVE_TTL_SECONDS=900   # 15 min
STOCK_RECONCILE_INTERVAL_MS=300000  # 5 min

# Flash Sale
FLASH_SALE_QUEUE_KEY_PREFIX=flash_sale:queue
FLASH_SALE_BATCH_SIZE=100
FLASH_SALE_LUA_DEQUEUE=true

# BullMQ (background jobs)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_CONCURRENCY=10
